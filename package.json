{
  "name": "taskflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c bgBlue,bgGreen \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
